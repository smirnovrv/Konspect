	Если Не мВыделенныйТекст = "" Тогда
		НомерВставки = СтрНайти(Элементы.Состав.ТекущиеДанные.Значение, мВыделенныйТекст);
		НомерВставки = НомерВставки + СтрДлина(мВыделенныйТекст) + 1; 

